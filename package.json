{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:all": "concurrently --names \"vite,serve,reverb,queue\" --prefix-colors \"cyan,green,yellow,magenta\" \"npm run dev\" \"php artisan serve\" \"php artisan reverb:start\" \"php artisan queue:work\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint resources/js --ext .js,.jsx --max-warnings 0",
        "lint:fix": "eslint resources/js --ext .js,.jsx --fix",
        "format": "prettier --write resources/js",
        "format:check": "prettier --check resources/js"
    },
    "devDependencies": {
        "@headlessui/react": "^2.0.0",
        "@inertiajs/react": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.1.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "jsdom": "^29.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "postcss": "^8.4.31",
        "prettier": "^3.8.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^4.2.2",
        "vite": "^8.0.0",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.2"
    }
}
